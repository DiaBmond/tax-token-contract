# ==============================================================================
# Tax Token Ecosystem - Environment Variables Example
# ==============================================================================
# Usage: Copy this file, rename it to '.env', and fill in your actual credentials.
# WARNING: NEVER commit or push your actual '.env' file to GitHub!
# ==============================================================================

# [PUBLIC] URL for connecting to the Sepolia Testnet.
# You can use the public node below, or replace it with your Alchemy / Infura URL.
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# [SECRET] Private Key of the deployer's wallet (Owner).
# Typically starts with 0x followed by 64 characters. (DO NOT put your real key here!)
SEPOLIA_PRIVATE_KEY="0x_your_wallet_private_key_here"

# [SECRET/OPTIONAL] Additional Network URLs for future deployments.
NETWORK_URL="your_network_url_here"